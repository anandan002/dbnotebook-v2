# Copy this file to .env.host-postgres and fill in real secrets.
# .env.host-postgres is ignored by Git.

# This file only contains Docker/host-Postgres overrides.
# Provider keys and model settings are loaded from ../.env first.
# deploy/docker-compose.host-postgres.yml loads ../.env, then this file.

# Host PostgreSQL reached from Docker through host.docker.internal.
POSTGRES_HOST=host.docker.internal
POSTGRES_PORT=5432
POSTGRES_DB=dbnotebook_dev
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me
# URL-encode special characters in the password for DATABASE_URL.
DATABASE_URL=postgresql://postgres:replace_with_url_encoded_password@host.docker.internal:5432/dbnotebook_dev

# pgvector. Keep this aligned with the embedding model configured in ../.env.
PGVECTOR_TABLE_NAME=embeddings
PGVECTOR_EMBED_DIM=1536

# SQL Chat
SQL_CHAT_ENCRYPTION_KEY=
SQL_CHAT_SKIP_READONLY_CHECK=false
SQL_CHAT_AUTO_INIT_FEW_SHOT=false
FEW_SHOT_MAX_EXAMPLES=100000

# Optional API authentication
API_KEY=

# Flask session stability
FLASK_SECRET_KEY=change_me_to_a_random_hex_value

# App is served behind Nginx at /dbnotebook in the host-Postgres Docker setup.
# The compose file also hard-sets this value at runtime.
DBNOTEBOOK_BASE_PATH=/dbnotebook

# Optional observability/background jobs
RBAC_STRICT_MODE=false
LANGFUSE_ENABLED=false
FEEDBACK_ANALYZER_ENABLED=false
DISABLE_BACKGROUND_WORKERS=false
DISABLE_RERANKER=false
